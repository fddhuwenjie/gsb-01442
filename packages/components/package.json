{
  "name": "@alkaid-plus/components",
  "version": "1.0.0",
  "description": "Vue 3 components based on Element Plus",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*/index.mjs",
      "require": "./dist/*/index.js",
      "types": "./dist/*/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build"
  },
  "dependencies": {
    "@alkaid-plus/hooks": "workspace:*",
    "@alkaid-plus/utils": "workspace:*",
    "element-plus": "^2.5.3"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.3",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "vite": "^5.0.12",
    "vite-plugin-dts": "^3.7.1",
    "vue": "^3.4.15"
  }
}
