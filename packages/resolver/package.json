{
  "name": "@alkaid-plus/resolver",
  "version": "1.0.0",
  "description": "Resolver for unplugin-vue-components to auto-import Alkaid Plus components",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup"
  },
  "peerDependencies": {
    "unplugin-vue-components": ">=0.22.0"
  },
  "devDependencies": {
    "@alkaid-plus/components": "workspace:*",
    "tsup": "^8.0.1",
    "unplugin-vue-components": "^0.26.0"
  }
}
